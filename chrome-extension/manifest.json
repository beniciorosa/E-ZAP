{
  "manifest_version": 3,
  "name": "E-ZAP",
  "version": "1.4.3",
  "description": "E-ZAP — Gestão inteligente para WhatsApp Business",
  "permissions": ["storage", "activeTab", "alarms", "tabs"],
  "host_permissions": ["https://api.hubapi.com/*", "https://eklcsufcwjtxlpxhncnt.supabase.co/*", "https://xsqpqdjffjqxdcmoytfc.supabase.co/*", "https://ipapi.co/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["auth.js", "content.js", "msg.js", "slice.js", "abas.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "E-ZAP Settings"
  },
  "icons": {
    "16": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

{
  "manifest_version": 3,
  "name": "E-ZAP",
  "version": "1.9.91",
  "description": "E-ZAP — Gestão inteligente para WhatsApp Business",
  "permissions": ["storage", "activeTab", "alarms", "tabs", "identity"],
  "oauth2": {
    "client_id": "337699127860-grlcbsjc8pkvesv9vgor04ugpjq3uk2l.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive",
      "https://www.googleapis.com/auth/documents"
    ]
  },
  "host_permissions": ["https://api.hubapi.com/*", "https://eklcsufcwjtxlpxhncnt.supabase.co/*", "https://xsqpqdjffjqxdcmoytfc.supabase.co/*", "https://ipapi.co/*", "https://api.openai.com/*", "https://www.googleapis.com/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["early-hide.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["transcribe-interceptor.js", "store-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["event-bus.js", "sidebar-manager.js", "theme.js", "api.js", "auth.js", "content.js", "msg.js", "slice.js", "abas.js", "widget.js", "transcribe.js", "notes.js", "geia.js", "admin-overlay.js", "flow-engine.js", "msg-capture.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meet-recorder.js"],
      "css": ["meet-recorder.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "E-ZAP — v1.9.91"
  },
  "icons": {
    "16": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

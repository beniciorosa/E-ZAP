{
  "manifest_version": 3,
  "name": "E-ZAP",
  "version": "1.8.49",
  "description": "E-ZAP — Gestão inteligente para WhatsApp Business",
  "permissions": ["storage", "activeTab", "alarms", "tabs"],
  "host_permissions": ["https://api.hubapi.com/*", "https://eklcsufcwjtxlpxhncnt.supabase.co/*", "https://xsqpqdjffjqxdcmoytfc.supabase.co/*", "https://ipapi.co/*", "https://api.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["transcribe-interceptor.js", "store-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["api.js", "auth.js", "content.js", "msg.js", "slice.js", "abas.js", "widget.js", "transcribe.js", "geia.js", "flow-engine.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "E-ZAP Settings"
  },
  "icons": {
    "16": "icons/icon48.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
